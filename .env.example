# For more information, please see the README.md
SUNO_COOKIE=
TWOCAPTCHA_KEY= # Obtain from 2captcha.com
# Optional: rucaptcha for CN VPS; polling interval ms (default 8000, min 5000 recommended)
# TWOCAPTCHA_PROVIDER=2captcha
# TWOCAPTCHA_POLLING_INTERVAL=8000
# TWOCAPTCHA_POLL_RETRIES=5

# API auth (optional): set both to enable Bearer token protection on /api/* and /v1/*
API_AUTH_ENABLED=false
API_SECRET= # e.g. openssl rand -hex 32
BROWSER=chromium # `chromium` or `firefox`, although `chromium` is highly recommended
BROWSER_GHOST_CURSOR=false
BROWSER_LOCALE=en
BROWSER_HEADLESS=true
BROWSER_DISABLE_GPU=true
# Save /tmp/suno-captcha-*.png when CAPTCHA UI automation fails (Linux VPS)
CAPTCHA_DEBUG_SCREENSHOT=false
